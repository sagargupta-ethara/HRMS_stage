# Copy to `.env` and fill in. Any var prefixed NEXT_PUBLIC_ is exposed to the
# browser — note that NONE of the Documenso secrets use that prefix, so they are
# only ever readable from server code (route handlers / server actions).

DATABASE_URL="file:./dev.db"

# Public base URL of THIS app, used to construct the webhook callback URL we
# register with Documenso, and signing redirect links.
APP_BASE_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# Documenso integration (SERVER-SIDE ONLY)
# ---------------------------------------------------------------------------
# Targets the Documenso v2 ("envelope") API. Either form works — the app
# normalises it:
#   Cloud:        https://app.documenso.com/api/v2   (or just https://app.documenso.com)
#   Self-hosted:  https://documenso.your-company.com/api/v2
# Leave DOCUMENSO_API_URL / DOCUMENSO_API_KEY blank to run in MOCK mode: the app
# simulates document creation + signing and fires webhooks at itself so you can
# demo the full flow without an account.
DOCUMENSO_API_URL="https://app.documenso.com/api/v2"

# Create under: Documenso > Settings > API Tokens. Sent verbatim as the
# `Authorization: api_xxx` header (NO "Bearer" prefix). Treat as a secret.
DOCUMENSO_API_KEY=""

# Documenso signs webhook payloads with this secret; we verify it via the
# `X-Documenso-Secret` header on inbound webhooks at /api/webhooks/documenso.
DOCUMENSO_WEBHOOK_SECRET=""

# How sent documents are distributed: EMAIL (default — Documenso emails signers)
# or NONE (creates the envelope + recipients but sends no emails; good for a
# first dry-run where you review the result in the Documenso dashboard).
DOCUMENSO_DISTRIBUTION_METHOD="EMAIL"
