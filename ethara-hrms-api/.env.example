# ethara-hrms-api — environment template
# Copy to `.env` and fill in real values. NEVER commit the real .env.
# Generate strong secrets with:  python -c "import secrets; print(secrets.token_urlsafe(48))"

# --- Core ---
PORT=3001
APP_ENV=development            # development | production
APP_DEBUG=false
FRONTEND_URL=http://localhost:3000
EXTRA_ALLOWED_ORIGINS=http://localhost:3000

# --- Database (Postgres) ---
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@localhost:5432/ethara_hrms
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=10

# --- Redis / Celery ---
REDIS_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_ALWAYS_EAGER=true  # true = run tasks inline (no worker needed for dev)
CACHE_ENABLED=false

# --- Auth / JWT (REQUIRED — set long random strings) ---
JWT_SECRET=CHANGE_ME
JWT_REFRESH_SECRET=CHANGE_ME
JWT_EXPIRES_IN_MINUTES=60
JWT_REFRESH_EXPIRES_IN_DAYS=7
OTP_EXPIRY_MINUTES=10
DEFAULT_TEMP_PASSWORD=CHANGE_ME
AADHAAR_PEPPER=CHANGE_ME       # random string used to hash Aadhaar numbers

# --- Email ---
EMAIL_BACKEND=console          # console (dev, prints to log) | smtp
EMAIL_FROM=no-reply@example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# --- Storage (uploads) ---
STORAGE_BACKEND=local          # local | s3
LOCAL_STORAGE_PATH=./uploads
AWS_REGION=ap-south-1
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
TEXTRACT_BUCKET=

# --- Documenso (e-signature) ---
DOCUMENSO_BASE_URL=https://app.documenso.com/api/v2
DOCUMENSO_SIGNING_BASE_URL=https://app.documenso.com/sign
DOCUMENSO_API_KEY=
DOCUMENSO_WEBHOOK_SECRET=
DOCUMENSO_RATE_LIMIT_DELAY_MS=250
DOCUMENSO_SYNC_BATCH_SIZE=25

# --- OCR / LLM (document parsing; all optional) ---
OCR_BACKEND=tesseract          # tesseract | google | textract
OCR_LANGUAGES=eng
OCR_DPI=300
TESSERACT_COMMAND=tesseract
LLM_BACKEND=none               # none | gemini | openai | vertex
GEMINI_API_KEY=
GEMINI_MODEL=
GEMINI_OCR_FALLBACK=false
OPENAI_API_KEY=
OPENAI_MODEL=
VERTEX_AI_ENABLED=false
VERTEX_AI_API_KEY=
VERTEX_AI_PROJECT_ID=
VERTEX_AI_LOCATION=
VERTEX_AI_MODEL=
GOOGLE_DOCUMENT_AI_PROJECT_ID=
GOOGLE_DOCUMENT_AI_LOCATION=
GOOGLE_DOCUMENT_AI_PROCESSOR_ID=
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=

# --- eSSL biometric attendance device DB (external MSSQL; optional) ---
ESSL_DB_HOST=
ESSL_DB_PORT=1433
ESSL_DB_NAME=
ESSL_DB_USER=
ESSL_DB_PASSWORD=
ESSL_TDS_VERSION=7.4
ESSL_LOGIN_TIMEOUT_SECONDS=15
ESSL_QUERY_TIMEOUT_SECONDS=60
ATTENDANCE_BUSINESS_TIMEZONE=Asia/Kolkata
ATTENDANCE_FINALIZE_AFTER_HOUR=20

# --- greytHR integration (optional) ---
GREYTHR_BASE_URL=https://api.greythr.com
GREYTHR_DOMAIN=
GREYTHR_API_USERNAME=
GREYTHR_API_PASSWORD=
