# ethara-hrms (Next.js frontend) — environment template
# Copy to `.env.local` and adjust. NEVER commit the real .env.local.

# API base path used by the browser. The app is served same-origin and Next.js
# rewrites this prefix to the backend (see next.config.ts), so keep it relative.
NEXT_PUBLIC_API_URL=/api/v1

# Server-side proxy targets (used by Next.js rewrites). Point these at your
# running backend API and wiki service.
INTERNAL_API_ORIGIN=http://127.0.0.1:3001
INTERNAL_WIKI_ORIGIN=http://127.0.0.1:8001
